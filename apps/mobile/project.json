{
  "name": "mobile",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "@nx/react-native:start",
      "options": {
        "port": 8081
      }
    },
    "run-ios": {
      "executor": "@nx/react-native:run-ios",
      "options": {
        "simulator": "iPhone 15 Pro"
      }
    },
    "run-android": {
      "executor": "@nx/react-native:run-android"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/mobile/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "bundle": {
      "executor": "@nx/react-native:bundle",
      "outputs": ["{options.bundleOutput}"],
      "options": {
        "entryFile": "apps/mobile/src/main.tsx",
        "platform": "ios",
        "bundleOutput": "dist/apps/mobile/ios/main.jsbundle"
      },
      "configurations": {
        "production": {
          "minify": true,
          "sourcemapOutput": "dist/apps/mobile/ios/main.jsbundle.map"
        }
      }
    }
  },
  "tags": ["type:app", "scope:mobile", "platform:react-native"],
  "implicitDependencies": ["api-interfaces"]
}
