{
  "name": "azure-client",
  "sourceRoot": "libs/azure-client/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/azure-client",
        "main": "libs/azure-client/src/index.ts",
        "tsConfig": "libs/azure-client/tsconfig.lib.json",
        "assets": ["libs/azure-client/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/azure-client/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    }
  },
  "tags": ["type:lib", "scope:azure"],
  "implicitDependencies": ["api-interfaces"]
}