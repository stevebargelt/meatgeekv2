{
  "name": "api-specs",
  "sourceRoot": "libs/api-specs/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/api-specs",
        "main": "libs/api-specs/src/index.ts",
        "tsConfig": "libs/api-specs/tsconfig.lib.json",
        "assets": [
          "libs/api-specs/*.md",
          {
            "input": "libs/api-specs/spec",
            "glob": "**/*",
            "output": "spec"
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/api-specs/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --project libs/api-specs/tsconfig.lib.json libs/api-specs/src/lib/mock-server/start.ts",
        "cwd": "."
      }
    },
    "mock": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --project libs/api-specs/tsconfig.lib.json libs/api-specs/src/lib/mock-server/start.ts",
        "cwd": "."
      }
    },
    "validate-spec": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @apidevtools/swagger-parser validate libs/api-specs/spec/openapi.yaml",
        "cwd": "."
      }
    },
    "generate-types": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx openapi-typescript libs/api-specs/spec/openapi.yaml -o libs/api-specs/src/generated/types.d.ts",
        "cwd": "."
      }
    }
  },
  "tags": ["type:lib", "scope:shared"]
}
