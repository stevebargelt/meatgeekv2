{
  "name": "data-models",
  "sourceRoot": "libs/data-models/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/data-models",
        "main": "libs/data-models/src/index.ts",
        "tsConfig": "libs/data-models/tsconfig.lib.json",
        "assets": ["libs/data-models/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/data-models/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    }
  },
  "tags": ["type:lib", "scope:shared"],
  "implicitDependencies": ["api-interfaces", "utils"]
}